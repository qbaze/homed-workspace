#!/usr/bin/env bash
# homed-workspace-setup — EXPLICITLY (with your consent) wire up PAM integration:
#   * /etc/pam.d/su        : keyring + systemd (all `optional` modules)
#   * display manager PAM  : client logout hook
# This does NOT run during the pacman transaction — you invoke it yourself.
# Everything is idempotent and reversible:  sudo homed-workspace-setup [--undo]
set -euo pipefail
[[ $EUID -eq 0 ]] || { echo "run as root: sudo homed-workspace-setup [--undo]" >&2; exit 1; }

B='# >>> homed-workspace >>>'; E='# <<< homed-workspace <<<'

dm_pam() {
  local dm; dm=$(systemctl show -p Id --value display-manager.service 2>/dev/null) || return 0
  dm=${dm%.service}; [[ -n $dm && -f /etc/pam.d/$dm ]] && echo "/etc/pam.d/$dm"
}
add() {  # $1=file $2=body
  [[ -f $1 ]] || { echo "  skip (missing): $1"; return 0; }
  grep -qF "$B" "$1" && { echo "  already present: $1"; return 0; }
  printf '\n%s\n%s\n%s\n' "$B" "$2" "$E" >> "$1"; echo "  added: $1"
}
del() { [[ -f $1 ]] && sed -i "/$B/,/$E/d" "$1" && echo "  cleaned: $1"; }

if [[ ${1:-} == --undo ]]; then
  echo "Removing PAM integration:"
  del /etc/pam.d/su
  d=$(dm_pam); [[ -n $d ]] && del "$d"
  echo "Done. (client linger left intact: loginctl disable-linger <user>)"
  exit 0
fi

echo "Wiring PAM integration ('optional' modules — cannot cause lockout):"
add /etc/pam.d/su \
"auth       optional   pam_gnome_keyring.so
session    optional   pam_systemd.so
session    optional   pam_gnome_keyring.so auto_start"

d=$(dm_pam)
if [[ -n $d ]]; then
  add "$d" "session    optional   pam_exec.so /usr/bin/homed-workspace-logout"
else
  echo "  !! no display manager detected — add the logout hook to your DM's PAM manually:"
  echo "     session optional pam_exec.so /usr/bin/homed-workspace-logout"
fi
echo "Done. Log out and back in once so PAM picks up the changes."
