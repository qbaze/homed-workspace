#!/usr/bin/env bash
# homed-workspace-setup — EXPLICITLY (with your consent) install the client-logout
# hook into your display manager's PAM stack, so that when you log out, all client
# homed sessions are torn down and their encrypted homes deactivated.
#
# This does NOT run during the pacman transaction — you invoke it yourself.
# Idempotent and reversible:  sudo homed-workspace-setup [--undo]
#
# NOTE: this no longer touches /etc/pam.d/su. The old su/PAM keyring hook was tied
# to an `su -l` anchor that does not work with systemd-homed ("Called without
# reference on home taken"), so runas now activates homes via `homectl activate`.
# Automatic keyring unlock is therefore not wired here; see README (Keyring).
set -euo pipefail
[[ $EUID -eq 0 ]] || { echo "run as root: sudo homed-workspace-setup [--undo]" >&2; exit 1; }

B='# >>> homed-workspace >>>'; E='# <<< homed-workspace <<<'

dm_pam() {
  local dm; dm=$(systemctl show -p Id --value display-manager.service 2>/dev/null) || return 0
  dm=${dm%.service}; [[ -n $dm && -f /etc/pam.d/$dm ]] && echo "/etc/pam.d/$dm"
}
add() {  # $1=file $2=body
  [[ -f $1 ]] || { echo "  skip (missing): $1"; return 0; }
  grep -qF "$B" "$1" && { echo "  already present: $1"; return 0; }
  printf '\n%s\n%s\n%s\n' "$B" "$2" "$E" >> "$1"; echo "  added: $1"
}
del() { [[ -f $1 ]] && sed -i "/$B/,/$E/d" "$1" && echo "  cleaned: $1"; }

if [[ ${1:-} == --undo ]]; then
  echo "Removing the logout hook:"
  # also strip the legacy /etc/pam.d/su block, in case an older version added it
  del /etc/pam.d/su
  d=$(dm_pam); [[ -n $d ]] && del "$d"
  echo "Done. (client linger left intact: loginctl disable-linger <user>)"
  exit 0
fi

echo "Installing the client-logout hook:"
d=$(dm_pam)
if [[ -n $d ]]; then
  add "$d" "session    optional   pam_exec.so /usr/bin/homed-workspace-logout"
else
  echo "  !! no display manager detected — add the logout hook to your DM's PAM manually:"
  echo "     session optional pam_exec.so /usr/bin/homed-workspace-logout"
fi
# clean up the legacy su block if a previous version of this tool added it
if grep -qF "$B" /etc/pam.d/su 2>/dev/null; then
  echo "Removing obsolete /etc/pam.d/su block from an earlier version:"
  del /etc/pam.d/su
fi
echo "Done. Log out and back in once so PAM picks up the change."
