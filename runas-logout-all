#!/usr/bin/env bash
# runas-logout-all — ubij sesje klientów homed i zdeaktywuj ich home.
# Odpalane jako root z pam_exec (close_session głównego usera). Bezpieczne ręcznie.
set -uo pipefail

if [[ -n ${PAM_TYPE:-} && ${PAM_TYPE} != close_session ]]; then exit 0; fi
KEEP="${PAM_USER:-}"

mapfile -t users < <(homectl list --no-legend 2>/dev/null | awk '{print $1}')
[[ ${#users[@]} -gt 0 ]] || exit 0
drop=(); for u in "${users[@]}"; do [[ $u == "$KEEP" ]] || drop+=("$u"); done
[[ ${#drop[@]} -gt 0 ]] || exit 0

# cofnij dostęp X, który runas nadał klientom (least-privilege sprzątanie)
for u in "${drop[@]}"; do xhost "-si:localuser:$u" 2>/dev/null || true; done

for u in "${drop[@]}"; do loginctl terminate-user "$u" 2>/dev/null || true; done
sleep 1
for u in "${drop[@]}"; do
  if loginctl list-users --no-legend 2>/dev/null | awk '{print $2}' | grep -qxF "$u"; then
    loginctl kill-user --signal=SIGKILL "$u" 2>/dev/null || true
  fi
done
sleep 1
for u in "${drop[@]}"; do
  homectl deactivate "$u" 2>/dev/null || { sleep 1; homectl deactivate "$u" 2>/dev/null || true; }
done
exit 0
