#!/usr/bin/env bash
# runas-setup — JAWNIE (za zgodą usera) dopina integrację z PAM:
#   * /etc/pam.d/su         : keyring + systemd (same moduły `optional`)
#   * PAM display managera  : hak wylogowania klientów
# To NIE dzieje się przy instalacji pacmana — świadomie odpalasz to sam.
# Wszystko idempotentne i odwracalne:  sudo runas-setup [--undo]
set -euo pipefail
[[ $EUID -eq 0 ]] || { echo "uruchom jako root: sudo runas-setup [--undo]" >&2; exit 1; }

B='# >>> runas-workspace >>>'; E='# <<< runas-workspace <<<'

dm_pam() {
  local dm; dm=$(systemctl show -p Id --value display-manager.service 2>/dev/null) || return 0
  dm=${dm%.service}; [[ -n $dm && -f /etc/pam.d/$dm ]] && echo "/etc/pam.d/$dm"
}
add() {  # $1=plik $2=treść
  [[ -f $1 ]] || { echo "  pomijam (brak): $1"; return 0; }
  grep -qF "$B" "$1" && { echo "  już jest: $1"; return 0; }
  printf '\n%s\n%s\n%s\n' "$B" "$2" "$E" >> "$1"; echo "  dodano: $1"
}
del() { [[ -f $1 ]] && sed -i "/$B/,/$E/d" "$1" && echo "  wyczyszczono: $1"; }

if [[ ${1:-} == --undo ]]; then
  echo "Cofam integrację PAM:"
  del /etc/pam.d/su
  d=$(dm_pam); [[ -n $d ]] && del "$d"
  echo "Gotowe. (linger klientów nietknięty: loginctl disable-linger <user>)"
  exit 0
fi

echo "Dopinam integrację PAM (moduły 'optional' — lockout niemożliwy):"
add /etc/pam.d/su \
"auth       optional   pam_gnome_keyring.so
session    optional   pam_systemd.so
session    optional   pam_gnome_keyring.so auto_start"

d=$(dm_pam)
if [[ -n $d ]]; then
  add "$d" "session    optional   pam_exec.so /usr/bin/runas-logout-all"
else
  echo "  !! nie wykryto display managera — hak wylogowania dodaj ręcznie do PAM DM:"
  echo "     session optional pam_exec.so /usr/bin/runas-logout-all"
fi
echo "Gotowe. Wyloguj się i zaloguj raz, żeby PAM złapał zmiany."
