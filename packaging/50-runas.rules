// Członkowie `wheel` mogą wstrzykiwać się do sesji klientów, aktywować/deaktywować
// ich home i włączać linger — bez pytania polkit o hasło admina.
// `wheel` bo taki user i tak może `sudo su - X`: zero eskalacji, zero osobnej grupy.
polkit.addRule(function(action, subject) {
    if (subject.isInGroup("wheel") &&
        (action.id == "org.freedesktop.machine1.shell" ||
         action.id == "org.freedesktop.machine1.login" ||
         action.id == "org.freedesktop.home1.activate-home" ||
         action.id == "org.freedesktop.home1.deactivate-home" ||
         action.id == "org.freedesktop.login1.set-user-linger")) {
        return polkit.Result.YES;
    }
});
