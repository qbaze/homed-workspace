#!/usr/bin/env bash
# homed-workspace-notify — desktop notification on every workspace change.
# Event-driven on X11 (xprop -spy) / Sway (swaymsg subscribe), polling fallback
# elsewhere — all hidden behind watch_ws() in the shared library. Meant to run as
# a `systemctl --user` service (opt-in).
set -uo pipefail

_LIB=/usr/lib/homed-workspace/lib.sh
[[ -r $_LIB ]] || _LIB="$(dirname "$(readlink -f "$0")")/lib/lib.sh"
# shellcheck source=/dev/null
source "$_LIB"

# --- attach to the graphical session -----------------------------------------
# A systemd --user manager usually starts before X and without DISPLAY/XAUTHORITY
# in its environment, so discover them instead of assuming. Exit non-zero when we
# cannot attach: the unit has Restart=always, so systemd retries until X is up.
find_display() {
  [[ -n ${DISPLAY:-} ]] && return 0
  local s
  for s in /tmp/.X11-unix/X*; do
    [[ -S $s ]] || continue
    export DISPLAY=":${s##*/X}"
    return 0
  done
  return 1
}
find_xauthority() {
  [[ -n ${XAUTHORITY:-} && -r ${XAUTHORITY:-} ]] && return 0
  local c
  for c in "$XDG_RUNTIME_DIR"/xauth_* "$HOME/.Xauthority"; do
    [[ -r $c ]] || continue
    export XAUTHORITY="$c"
    return 0
  done
  return 0   # not fatal: same-user access often works without it
}

if [[ -z ${WAYLAND_DISPLAY:-} && -z ${SWAYSOCK:-} ]]; then
  find_display || { echo "no X display found yet; will retry" >&2; exit 1; }
  find_xauthority
  # verify we can actually talk to the server before entering the watch loop
  if command -v xprop >/dev/null 2>&1; then
    xprop -root -notype _NET_CURRENT_DESKTOP >/dev/null 2>&1 \
      || { echo "cannot reach X server on $DISPLAY yet; will retry" >&2; exit 1; }
  fi
fi

last=""
watch_ws | while read -r _; do
  name=$(current_ws 2>/dev/null || true)
  [[ -n $name && $name != "$last" ]] || continue
  last=$name
  notify-send -a homed-workspace -u low "Workspace" "$name" 2>/dev/null || true
done

# watch_ws ended (X went away, tool died) -> fail so systemd restarts us
echo "watch_ws exited; restarting" >&2
exit 1
