#!/usr/bin/env bash
# runas — run a command as the systemd-homed client user that owns the current
# XFCE workspace.
#
# Model: one password login per client per boot (activates the encrypted home
# AND unlocks the keyring via PAM); linger keeps the session alive; every later
# command is injected into that live session with `machinectl shell` — no further
# password prompts, with working audio and keyring. Linger and audio self-configure
# on first use.

set -euo pipefail

RUNAS_DIR=/run/homed-workspace          # dedicated dir (tmpfiles.d, sticky)
me=$(id -un); myuid=$(id -u)
SOCK="${RUNAS_DIR}/pulse-${myuid}"       # audio socket unique to your UID
ANCHOR_MARK="homed-workspace-anchor"

current_ws() {
  local cur; cur=$(xdotool get_desktop) || return 1
  # take fields from 10 onward -> robust to multi-monitor 'WA:' shifting
  wmctrl -d | awk -v c="$cur" '$1==c{s="";for(i=10;i<=NF;i++)s=s(i>10?" ":"")$i;print s}'
}
is_client() {
  local line uid shell
  line=$(getent passwd "$1") || return 1
  uid=$(cut -d: -f3 <<<"$line"); shell=$(cut -d: -f7 <<<"$line")
  [[ $uid -ge 1000 && $uid -lt 65000 && $shell =~ (bash|zsh|fish)$ ]]
}

# Audio: generate a per-user pipewire-pulse drop-in; the socket is your own file,
# so you may fix its permissions yourself. Path lives under /run/homed-workspace
# (root-owned, sticky) rather than bare /tmp.
ensure_audio() {
  local dropin="$HOME/.config/pipewire/pipewire-pulse.conf.d/20-homed-workspace.conf"
  if [[ ! -e $dropin ]]; then
    mkdir -p "${dropin%/*}"
    cat > "$dropin" <<CONF
# generated by homed-workspace — shared audio socket for client sessions
pulse.properties = {
    server.address = [
        "unix:native"
        { address = "unix:${SOCK}"  client.access = "unrestricted" }
    ]
}
CONF
    systemctl --user restart pipewire-pulse 2>/dev/null || true
    for _ in $(seq 1 20); do [[ -S $SOCK ]] && break; sleep 0.2; done
  fi
  if [[ -S $SOCK && $(stat -c '%a' "$SOCK" 2>/dev/null) != 666 ]]; then
    chmod 0666 "$SOCK" 2>/dev/null || true
  fi
}

target=$(current_ws || true)
if [[ -z ${target:-} || $target == "$me" ]] || ! is_client "$target"; then
  exec "$@"
fi
tuid=$(id -u "$target")

# Linger: enable once, lazily (polkit authorises wheel for set-user-linger)
if ! loginctl show-user "$target" -p Linger --value 2>/dev/null | grep -qx yes; then
  loginctl enable-linger "$target" 2>/dev/null || true
fi

session_up() {
  loginctl list-sessions --no-legend 2>/dev/null | awk '{print $3}' | grep -qxF "$target"
}
if ! session_up; then
  # The only password prompt (it is the home encryption key). `su -l` runs the
  # full PAM stack, so with the PAM integration enabled (see homed-workspace-setup)
  # it also unlocks the keyring in the same step.
  xfce4-terminal -T "$ANCHOR_MARK: $target" -e \
    "su -l \"$target\" -c \"echo '[$target] home + keyring unlocked'; exec sleep infinity\""
  for _ in $(seq 1 50); do session_up && break; sleep 0.3; done
  session_up || { echo "runas: session for $target did not come up" >&2; exit 1; }
fi

ensure_audio
xhost "+si:localuser:$target" >/dev/null

exec machinectl shell --quiet \
  --setenv=DISPLAY="${DISPLAY}" \
  --setenv=XDG_RUNTIME_DIR="/run/user/${tuid}" \
  --setenv=DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${tuid}/bus" \
  --setenv=PULSE_SERVER="unix:${SOCK}" \
  "${target}@.host" /usr/bin/env "$@"
