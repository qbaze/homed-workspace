#!/usr/bin/env bash
# runas — run a command as the systemd-homed client user that owns the current
# workspace. Model: the client's encrypted home is activated once per boot (one
# password, via `homectl activate` in a terminal); linger keeps user@UID.service
# alive; later commands are injected via `machinectl shell` — no password, with
# working audio. Linger and audio self-configure on first use.
#
# NOTE: this activates the home but does NOT unlock the login keyring (that needs
# a password-carrying PAM login, which neither `machinectl shell` nor `homectl
# activate` provide). See README (Keyring) for the recommended app-side approach.
set -euo pipefail

_LIB=/usr/lib/homed-workspace/lib.sh
[[ -r $_LIB ]] || _LIB="$(dirname "$(readlink -f "$0")")/lib/lib.sh"
# shellcheck source=/dev/null
source "$_LIB"   # provides is_client, current_ws (backend-switched)

RUNAS_DIR=/run/homed-workspace
me=$(id -un); myuid=$(id -u)
SOCK="${RUNAS_DIR}/pulse-${myuid}"
ACTIVATE_MARK="homed-workspace-activate"

ensure_audio() {
  local dropin="$HOME/.config/pipewire/pipewire-pulse.conf.d/20-homed-workspace.conf"
  if [[ ! -e $dropin ]]; then
    mkdir -p "${dropin%/*}"
    cat > "$dropin" <<CONF
# generated by homed-workspace — shared audio socket for client sessions
pulse.properties = {
    server.address = [
        "unix:native"
        { address = "unix:${SOCK}"  client.access = "unrestricted" }
    ]
}
CONF
    systemctl --user restart pipewire-pulse 2>/dev/null || true
    for _ in $(seq 1 20); do [[ -S $SOCK ]] && break; sleep 0.2; done
  fi
  if [[ -S $SOCK && $(stat -c '%a' "$SOCK" 2>/dev/null) != 666 ]]; then
    chmod 0666 "$SOCK" 2>/dev/null || true
  fi
}

target=$(current_ws 2>/dev/null || true)
if [[ -z ${target:-} || $target == "$me" ]] || ! is_client "$target"; then
  exec "$@"
fi
tuid=$(id -u "$target")

# Keep the user manager alive so `machinectl shell` has a target (idempotent).
if ! loginctl show-user "$target" -p Linger --value 2>/dev/null | grep -qx yes; then
  loginctl enable-linger "$target" 2>/dev/null || true
fi

# Decide on the REAL home state, not on session presence: linger keeps
# user@UID.service running even with the home inactive, so a loginctl check gives
# a false positive and we'd skip activation — then `machinectl shell` mounts the
# home per-command and prompts for the password every time (the broadcast + hang).
home_state() { homectl list --no-legend 2>/dev/null | awk -v u="$target" '$1==u{print $4}'; }

case "$(home_state)" in
  active) ;;                                   # already mounted -> nothing to do
  absent|"")                                   # record exists but image not here
    echo "runas: home for '$target' is absent — cannot activate on this machine." >&2
    echo "       Import/create it first, or run manually: homectl activate $target" >&2
    exit 1 ;;
  *)                                           # inactive / dirty -> activate it
    # Needs a tty for the password prompt (runas is launched from a keybind, not a
    # terminal). homectl activate mounts the home and exits; the mount persists.
    xfce4-terminal -T "$ACTIVATE_MARK: $target" -x homectl activate "$target"
    for _ in $(seq 1 100); do [[ $(home_state) == active ]] && break; sleep 0.3; done
    [[ $(home_state) == active ]] || {
      echo "runas: home for '$target' did not become active" >&2; exit 1; }
    ;;
esac

ensure_audio
xhost "+si:localuser:$target" >/dev/null

exec machinectl shell --quiet \
  --setenv=DISPLAY="${DISPLAY}" \
  --setenv=XDG_RUNTIME_DIR="/run/user/${tuid}" \
  --setenv=DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${tuid}/bus" \
  --setenv=PULSE_SERVER="unix:${SOCK}" \
  "${target}@.host" /usr/bin/env "$@"
