#!/usr/bin/env bash
# runas — run a command as the systemd-homed client user that owns the current
# workspace. Model: one password login per client per boot (activates encrypted
# home AND unlocks keyring); linger keeps the session; later commands are injected
# via `machinectl shell` — no password, working audio/keyring. Linger and audio
# self-configure on first use.
set -euo pipefail

_LIB=/usr/lib/homed-workspace/lib.sh
[[ -r $_LIB ]] || _LIB="$(dirname "$(readlink -f "$0")")/lib/lib.sh"
# shellcheck source=/dev/null
source "$_LIB"   # provides is_client, current_ws (backend-switched)

RUNAS_DIR=/run/homed-workspace
me=$(id -un); myuid=$(id -u)
SOCK="${RUNAS_DIR}/pulse-${myuid}"
ANCHOR_MARK="homed-workspace-anchor"

ensure_audio() {
  local dropin="$HOME/.config/pipewire/pipewire-pulse.conf.d/20-homed-workspace.conf"
  if [[ ! -e $dropin ]]; then
    mkdir -p "${dropin%/*}"
    cat > "$dropin" <<CONF
# generated by homed-workspace — shared audio socket for client sessions
pulse.properties = {
    server.address = [
        "unix:native"
        { address = "unix:${SOCK}"  client.access = "unrestricted" }
    ]
}
CONF
    systemctl --user restart pipewire-pulse 2>/dev/null || true
    for _ in $(seq 1 20); do [[ -S $SOCK ]] && break; sleep 0.2; done
  fi
  if [[ -S $SOCK && $(stat -c '%a' "$SOCK" 2>/dev/null) != 666 ]]; then
    chmod 0666 "$SOCK" 2>/dev/null || true
  fi
}

target=$(current_ws 2>/dev/null || true)
if [[ -z ${target:-} || $target == "$me" ]] || ! is_client "$target"; then
  exec "$@"
fi
tuid=$(id -u "$target")

if ! loginctl show-user "$target" -p Linger --value 2>/dev/null | grep -qx yes; then
  loginctl enable-linger "$target" 2>/dev/null || true
fi

session_up() {
  loginctl list-sessions --no-legend 2>/dev/null | awk '{print $3}' | grep -qxF "$target"
}
if ! session_up; then
  xfce4-terminal -T "$ANCHOR_MARK: $target" -e \
    "su -l \"$target\" -c \"echo '[$target] home + keyring unlocked'; exec sleep infinity\""
  for _ in $(seq 1 50); do session_up && break; sleep 0.3; done
  session_up || { echo "runas: session for $target did not come up" >&2; exit 1; }
fi

ensure_audio
xhost "+si:localuser:$target" >/dev/null

exec machinectl shell --quiet \
  --setenv=DISPLAY="${DISPLAY}" \
  --setenv=XDG_RUNTIME_DIR="/run/user/${tuid}" \
  --setenv=DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${tuid}/bus" \
  --setenv=PULSE_SERVER="unix:${SOCK}" \
  "${target}@.host" /usr/bin/env "$@"
