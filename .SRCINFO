pkgbase = homed-workspace-git
	pkgdesc = Run commands as the systemd-homed user matching your current workspace (one homed account per client)
	pkgver = 0.0.0
	pkgrel = 1
	url = https://github.com/USER/homed-workspace
	arch = any
	license = MIT
	makedepends = git
	depends = bash
	depends = systemd
	depends = polkit
	depends = wmctrl
	depends = xorg-xhost
	depends = xfce4-terminal
	optdepends = pipewire-pulse: shared audio socket for client sessions (auto-configured)
	optdepends = libnotify: workspace-change notifications (homed-workspace-notify)
	optdepends = xorg-xprop: event-driven workspace notifications on X11 (else polling)
	optdepends = xdotool: more robust active-workspace detection on X11
	optdepends = sway: workspace detection & notifications on Sway
	optdepends = hyprland: workspace detection on Hyprland
	provides = homed-workspace
	conflicts = homed-workspace
	source = homed-workspace::git+https://github.com/USER/homed-workspace.git
	sha256sums = SKIP

pkgname = homed-workspace-git
