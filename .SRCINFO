pkgbase = homed-workspace-git
	pkgdesc = Run commands as the systemd-homed user matching your current XFCE workspace (one homed account per client)
	pkgver = 0.0.0
	pkgrel = 1
	url = https://github.com/USER/homed-workspace
	arch = any
	license = MIT
	makedepends = git
	depends = bash
	depends = systemd
	depends = polkit
	depends = wmctrl
	depends = xdotool
	depends = xorg-xhost
	depends = xfce4-terminal
	optdepends = pipewire-pulse: shared audio socket for client sessions (auto-configured)
	optdepends = gnome-keyring: per-client secret unlock (enable via homed-workspace-setup)
	provides = homed-workspace
	conflicts = homed-workspace
	source = homed-workspace::git+https://github.com/USER/homed-workspace.git
	sha256sums = SKIP

pkgname = homed-workspace-git
